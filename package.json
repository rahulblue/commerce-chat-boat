{
  "name": "commerce-admin-chatbot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "check": "npm run check --workspace server && npm run check --workspace client",
    "deploy": "aio app deploy",
    "undeploy": "aio app undeploy",
    "deploy:dry": "aio app deploy --skip-deploy"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
