PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Optional. If absent, the app uses mock commerce data and no login is required.
# Once set, every admin logs in with their own real Commerce admin username/password
# (see SESSION_SECRET / COMMERCE_TOKEN_ENC_KEY below, both required once this is set).
# Example: https://stage.example.com
ADOBE_COMMERCE_BASE_URL=
# Usually /rest. Use /rest/default, /rest/all, or another store code if needed.
ADOBE_COMMERCE_REST_PREFIX=/rest
# Not used by the running server once login is live — only for scripts/test-commerce-rest.js
# manual debugging. Safe to leave blank.
ADOBE_COMMERCE_ADMIN_TOKEN=

# Required once ADOBE_COMMERCE_BASE_URL is set (login is then required).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
# Required once ADOBE_COMMERCE_BASE_URL is set. Encrypts each admin's Commerce token at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COMMERCE_TOKEN_ENC_KEY=
# Minutes of inactivity before a session expires. Slides forward on each request. Default 480 (8h).
SESSION_IDLE_TIMEOUT_MINUTES=480

# Optional. If absent, answers are generated from tool results without an LLM call.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
